# Copy to .env.local and fill in. .env.local is gitignored.

GOOGLE_CLOUD_PROJECT=civic-pulse-501608

# Base64-encoded service-account JSON key (for Render / any non-gcloud host).
# Create: IAM > Service Accounts > key (JSON), grant "BigQuery Data Viewer" +
# "BigQuery Job User", then:  base64 -w0 sa-key.json
# Locally you can OMIT this — Application Default Credentials
# (gcloud auth application-default login) are used as fallback.
GCP_SA_KEY_BASE64=

# Mapbox public token (https://account.mapbox.com/access-tokens/).
# Optional — without it the map panel shows a ranked-area fallback.
NEXT_PUBLIC_MAPBOX_TOKEN=
